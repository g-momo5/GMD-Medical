{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GMD Medical Platform",
  "version": "0.1.0",
  "identifier": "com.gmdmedical.platform",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "GMD Medical Platform",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "dialog:default",
            "dialog:allow-ask",
            "dialog:allow-save",
            "fs:default",
            "fs:allow-write-file",
            {
              "identifier": "fs:scope",
              "allow": [
                {
                  "path": "**"
                }
              ]
            },
            "opener:default",
            "sql:allow-load",
            "sql:allow-execute",
            "sql:allow-select",
            "sql:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../src/lib/templates/template_dislip.docx"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": []
    }
  }
}
