{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-ask",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-copy-file",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "**",
          "app": true
        }
      ]
    }
  ]
}
